@startuml
!pragma layout smetana
skinparam componentStyle rectangle
skinparam packageStyle rectangle

title package-manager 架构组件图

package "CLI 层" {
  [main.py\n参数解析/退出码映射]
}

package "MCP 控制面" {
  [mcp_server.py\nFastMCP + 鉴权 + scope授权]
  [control_plane.py\n工具白名单/结构化返回/安装互斥锁]
}

package "编排层" {
  [service.py\n选包/执行顺序]
}

package "配置层" {
  [config.py\nYAML 加载/校验]
  [models.py\n数据模型]
  [install_state.py\n已安装状态持久化]
  [file_lock.py\n文件锁/陈旧锁清理]
}

package "解析层" {
  [resolver.py\nURL/文件名/包元信息 解析]
}

package "执行层" {
  [installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器]
  [installer/registry.py\n安装器注册与插件发现]
  [installer/utils.ensure_local_or_download\n离线优先决策]
  [downloader.py\n下载/重试/磁盘空间]
  [verifier.py\nOpenSSL 验签]
}

package "基础设施" {
  [paths.py\n路径规范]
  [errors.py\n异常与退出码]
}

database "config/packages.yaml" as yaml
database ".package-manager/.install_state.yaml" as state
folder "_internal/packages" as cache
folder "config.install_dir 指定的安装目录" as install_root

[main.py\n参数解析/退出码映射] --> [service.py\n选包/执行顺序]
[mcp_server.py\nFastMCP + 鉴权 + scope授权] --> [control_plane.py\n工具白名单/结构化返回/安装互斥锁]
[control_plane.py\n工具白名单/结构化返回/安装互斥锁] --> [config.py\nYAML 加载/校验]
[control_plane.py\n工具白名单/结构化返回/安装互斥锁] --> [install_state.py\n已安装状态持久化]
[control_plane.py\n工具白名单/结构化返回/安装互斥锁] --> [service.py\n选包/执行顺序]
[control_plane.py\n工具白名单/结构化返回/安装互斥锁] --> [errors.py\n异常与退出码]
[service.py\n选包/执行顺序] --> [config.py\nYAML 加载/校验]
[service.py\n选包/执行顺序] --> [resolver.py\nURL/文件名/包元信息 解析]
[service.py\n选包/执行顺序] --> [installer/registry.py\n安装器注册与插件发现]
[service.py\n选包/执行顺序] --> [installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器]

[config.py\nYAML 加载/校验] --> [models.py\n数据模型]
[config.py\nYAML 加载/校验] --> yaml
[resolver.py\nURL/文件名/包元信息 解析] --> [models.py\n数据模型]
[resolver.py\nURL/文件名/包元信息 解析] --> [paths.py\n路径规范]

[installer/registry.py\n安装器注册与插件发现] --> [installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器]
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> [install_state.py\n已安装状态持久化]
[install_state.py\n已安装状态持久化] --> [file_lock.py\n文件锁/陈旧锁清理]
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> [installer/utils.ensure_local_or_download\n离线优先决策]
[installer/utils.ensure_local_or_download\n离线优先决策] --> [downloader.py\n下载/重试/磁盘空间]
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> [downloader.py\n下载/重试/磁盘空间]
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> [verifier.py\nOpenSSL 验签]
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> [paths.py\n路径规范]
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> [errors.py\n异常与退出码]

[install_state.py\n已安装状态持久化] --> state
[downloader.py\n下载/重试/磁盘空间] --> cache
[installer/base.py + installer/porting_*.py\n模板方法 + 产品安装器] --> install_root

[main.py\n参数解析/退出码映射] --> [errors.py\n异常与退出码]

@enduml
