@startuml

title 编译期流程（scripts/build.sh）

start
:输入版本参数(默认 26.0.RC1);
:校验必要工具\n(pyinstaller, openssl, python);
:更新 PACKAGE_VERSION 常量;
:读取 DER 根证书;
:转换生成 PEM;

partition "PyInstaller 打包" {
  :清理旧 build/dist;
  :执行 pyinstaller spec;
  :生成 dist/package-manager/package-manager;
}

partition "产物整理" {
  :创建 _internal 目录树;
  :复制 openssl 可执行文件到 _internal/openssl/bin;
  :复制 PEM 到 _internal/openssl/pems;
  :复制 openssl 动态库到 _internal/openssl/lib;
  :复制 config/packages.yaml 到 dist/config;
}

:产物校验\n(binary/_internal/pems/packages 目录);
if (校验通过?) then (yes)
  :输出构建成功信息;
  stop
else (no)
  :输出缺失项并退出非0;
  stop
endif

@enduml
