@startuml

title CLI 到安装执行时序图（含关键分支）

autonumber
actor User
participant "main.py" as Main
participant "service.py" as Service
participant "config.py" as Config
participant "resolver.py" as Resolver
participant "installer.registry.py" as Registry
participant "installer/base.py\n(BaseInstaller 子类)" as Installer
participant "install_state.py" as State
participant "file_lock.py" as Lock
participant "downloader.py" as Downloader
participant "verifier.py" as Verifier

User -> Main: 执行 package-manager\n(--name)
Main -> Service: run_with_builtin_config(...)
Service -> Config: get_runtime_config()
Config --> Service: RuntimeConfig

Service -> Service: select_packages(name)
loop 每个 PackageConfig
  Service -> Resolver: resolve_package(pkg, defaults)
  Resolver --> Service: ResolvedPackage
  Service -> Registry: get_installer_class(pkg)
  Registry --> Service: installer_cls
  Service -> Installer: installer.run()

    Installer -> State: get_installed_version(product)
    State --> Installer: installed_version | None

    alt installed_version != project_version
      Installer -> Installer: remove_previous_version()
    end

    Installer -> Installer: pre_check(installed_version)
    alt pre_check == skip
      Installer -> State: update_install_state(success)
      State -> Lock: acquire/reclaim-stale/release
      Installer --> Service: return
    else pre_check == install
      Installer -> Installer: ensure_local_or_download(package)
      alt 本地包命中且非空
        Installer --> Installer: use local package
      else 本地缺失或空文件
        Installer -> Downloader: download(package)
        Downloader --> Installer: package file
      end

      Installer -> Installer: ensure_local_or_download(signature)
      alt 本地签名命中且非空
        Installer --> Installer: use local signature
      else 本地签名缺失或空文件
        Installer -> Downloader: download(signature)
        Downloader --> Installer: signature file
      end

      opt devkit-porting: framework 包
        Installer -> Installer: ensure_local_or_download(framework package/signature)
      end

      Installer -> Verifier: verify_p7s_detached(...)
      Verifier --> Installer: ok / SignatureVerifyError

      Installer -> Installer: install()\n(产品子类实现)
      Installer -> Installer: post_install_check()
      alt cache_policy == keep_latest
        Installer -> Installer: keep_latest_cache()
      else cache_policy != keep_latest
        Installer -> Installer: cleanup_temp()
      end
      Installer -> State: update_install_state(success)
      State -> Lock: acquire/reclaim-stale/release
      Installer --> Service: return
    end

    alt 任一阶段抛 InstallerError
      Installer -> Installer: rollback_safely()
      Installer -> Installer: cleanup_temp_safely()
      Installer --> Service: raise InstallerError
    else 抛未知异常
      Installer -> Installer: rollback_safely()
      Installer -> Installer: cleanup_temp_safely()
      Installer --> Service: raise InstallError("Unhandled installer exception")
    end
end
Service --> Main: return 0

Main --> User: exit code

@enduml
