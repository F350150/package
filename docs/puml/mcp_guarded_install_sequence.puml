@startuml

title pm_skill_install_guarded 受控安装时序图

autonumber
actor User
participant "opencode" as OC
participant "Skill" as SK
participant "pm_skill_install_guarded" as TOOL
participant "PackageManagerControlPlane" as CP
participant "package-manager binary" as BIN
participant "install_state" as STATE

User -> OC: 安装 DevKit-Porting-Advisor，先 dry-run，再真实安装
OC -> SK: 触发 skill
SK -> TOOL: call(product)
TOOL -> CP: install_with_guardrails(product)

CP -> CP: health()

break unhealthy
  CP --> TOOL: error(phase=health)
  TOOL --> OC: fail
end

CP -> CP: list_packages()
CP -> CP: validate_product()

break unknown/disabled
  CP --> TOOL: error(phase=validate_product)
  TOOL --> OC: fail
end

CP -> CP: install(dry_run=true)

break dry_run fail
  CP --> TOOL: error(phase=dry_run)
  TOOL --> OC: fail
end

CP -> CP: acquire install lock
CP -> BIN: run --name &lt;product&gt;
BIN -> STATE: write installed_version/last_result
CP -> CP: release install lock
CP -> CP: status(product)
CP --> TOOL: success(phases)
TOOL --> OC: structured result
OC --> User: phase-by-phase summary

@enduml